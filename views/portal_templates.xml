<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <!-- Botón "Nuevo Ticket" en la lista de tickets del portal -->
    <template id="portal_helpdesk_ticket_inherit_create" name="Portal Helpdesk: Botón nuevo ticket" inherit_id="helpdesk.portal_helpdesk_ticket" priority="20">
        <xpath expr="//t[@t-call='portal.portal_searchbar']" position="replace">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <t t-call="portal.portal_searchbar">
                    <t t-set="title">Tickets</t>
                </t>
                <a href="/my/tickets/new" class="btn btn-primary ms-3">
                    <i class="fa fa-plus me-1"/> Nuevo Ticket
                </a>
            </div>
        </xpath>
    </template>

    <!-- Template del formulario de creación de ticket -->
    <template id="portal_create_ticket_form" name="Crear Ticket - Portal">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <!-- Breadcrumbs -->
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/my">Mi Cuenta</a></li>
                    <li class="breadcrumb-item"><a href="/my/tickets">Tickets</a></li>
                    <li class="breadcrumb-item active">Nuevo Ticket</li>
                </ol>
            </nav>

            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-transparent">
                            <h4 class="mb-0">Crear Nuevo Ticket</h4>
                        </div>
                        <div class="card-body">
                            <!-- Mensajes de error -->
                            <div t-if="error_message" class="alert alert-danger">
                                <t t-foreach="error_message" t-as="msg">
                                    <p class="mb-0" t-out="msg"/>
                                </t>
                            </div>

                            <form action="/my/tickets/new/submit" method="POST">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                <!-- Asunto -->
                                <div class="mb-3">
                                    <label for="name" class="form-label">Asunto <span class="text-danger">*</span></label>
                                    <input type="text" 
                                           t-att-class="'form-control ' + ('is-invalid' if error.get('name') else '')"
                                           id="name" name="name"
                                           t-att-value="form_data.get('name', '')"
                                           placeholder="Ingrese el asunto del ticket" required="required"/>
                                </div>

                                <div class="row">
                                    <!-- Equipo -->
                                    <div class="col-md-6 mb-3">
                                        <label for="team_id" class="form-label">Equipo de Helpdesk <span class="text-danger">*</span></label>
                                        <select 
                                            t-att-class="'form-select ' + ('is-invalid' if error.get('team_id') else '')"
                                            id="team_id" name="team_id"
                                            required="required">
                                            <option value="">Seleccione un equipo...</option>
                                            <t t-foreach="teams" t-as="team">
                                                <option t-att-value="team.id" t-att-selected="str(team.id) == form_data.get('team_id', '')">
                                                    <t t-out="team.name"/>
                                                </option>
                                            </t>
                                        </select>
                                    </div>

                                    <!-- Prioridad -->
                                    <div class="col-md-6 mb-3">
                                        <label for="priority" class="form-label">Prioridad</label>
                                        <select class="form-select" id="priority" name="priority">
                                            <option value="">Seleccione...</option>
                                            <option value="0" t-att-selected="form_data.get('priority') == '0'">Baja</option>
                                            <option value="1" t-att-selected="form_data.get('priority') == '1'">Media</option>
                                            <option value="2" t-att-selected="form_data.get('priority') == '2'">Alta</option>
                                            <option value="3" t-att-selected="form_data.get('priority') == '3'">Urgente</option>
                                        </select>
                                    </div>
                                </div>

                                <!-- Descripción -->
                                <div class="mb-4">
                                    <label for="description" class="form-label">Descripción</label>
                                    <textarea class="form-control" id="description" name="description" rows="6"
                                              placeholder="Describa su consulta o problema en detalle..."
                                              t-out="form_data.get('description', '')"/>
                                </div>

                                <!-- Botones -->
                                <div class="d-flex justify-content-between">
                                    <a href="/my/tickets" class="btn btn-light">
                                        <i class="fa fa-arrow-left me-1"/> Volver
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fa fa-paper-plane me-1"/> Enviar Ticket
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</data>
</odoo>
